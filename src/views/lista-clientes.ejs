<!DOCTYPE html>
<html>

<head>
    <title>
        Listagem de clientes | Nana Roupas
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/table.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/general.css">
    <link rel="stylesheet" href="/css/modal-excluir.css">
    <link rel="icon" type="image/png" href="/img/favicon.png">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
</head>

<body>
    <div class="containers-tabelaNavbar">
        <div class="navbar-container">
            <%- include('navbar', { paginaAtiva: paginaAtiva }) %>
        </div>

        <div class="layout">
            <div class="titulo-tabela">
                <h1>Clientes</h1>
            </div>

            <div class="containers-tabela">
                <div class="containers-CCF">

                    <label class="input-com-icon">
                        <input id="input-pesquisar" class="input-pesquisar" type="text"
                            placeholder="Pesquisar cliente pelo nome, cpf, e-mail ou telefone">

                        <svg id="btn-buscar" style="cursor: pointer;" class="icon-pesquisar" width="20" height="20"
                            viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <g clip-path="url(#clip0_526_615)">
                                <path
                                    d="M19 19L14.65 14.65M8.99999 4C10.3261 4 11.5978 4.5268 12.5355 5.46448C13.4732 6.40216 14 7.67392 14 9M17 9C17 10.5823 16.5308 12.129 15.6517 13.4446C14.7727 14.7602 13.5233 15.7855 12.0614 16.391C10.5996 16.9965 8.9911 17.155 7.43926 16.8463C5.88741 16.5376 4.46195 15.7757 3.34313 14.6569C2.22431 13.538 1.46241 12.1125 1.15373 10.5607C0.845053 9.00882 1.00343 7.40029 1.60893 5.93848C2.21443 4.47667 3.23981 3.22732 4.55541 2.34827C5.871 1.46922 7.41774 1 8.99999 1C11.1217 1 13.1566 1.84285 14.6568 3.34314C16.1571 4.84343 17 6.87827 17 9Z"
                                    stroke="#66334D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </g>
                            <defs>
                                <clipPath id="clip0_526_615">
                                    <rect width="20" height="20" fill="white" />
                                </clipPath>
                            </defs>
                        </svg>
                    </label>
                    <button id="btn-limpar" class="btn-limpar" style="display: none;"> Limpar pesquisa </button>
                    <!-- <a class="button-cadastrar" href="/cadastrar-cliente">Cadastrar cliente</a> -->
                    <!--<div class="button-filtrar">
                        <div>
                            <svg width="18" height="20" viewBox="0 0 18 20" fill="none"
                                xmlns="http://www.w3.org/2000/svg">
                                <path
                                    d="M3.46486 0.75C1.28486 0.75 -0.00515199 3.2 1.23485 5C3.10485 7.69 4.98485 10.37 6.85485 13.06V18.24L10.9649 19.25V13.06C12.8349 10.37 14.7148 7.69 16.5848 5C17.8448 3.2 16.5649 0.75 14.3749 0.75H3.46486Z"
                                    fill="#66334D" stroke="#66334D" stroke-width="1.5" stroke-linecap="round"
                                    stroke-linejoin="round" />
                            </svg>
                        </div> -->
                </div>
            </div>
            <div class="layout-tabela">
                <table class="tabela-clientes">

                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Telefone</th>
                            <th>Email</th>
                            <th>Ações</th>
                        </tr>
                    </thead>

                    <tbody id="tabela-corpo">
                        <% if (clientes && clientes.length> 0) { %>
                            <% clientes.forEach(cliente=> { %>
                                <tr id="linha-cliente-<%= cliente.id_cliente %>" style="cursor: pointer;">
                                    <td>
                                        <%= cliente.nome_cliente %>
                                    </td>
                                    <td>
                                        <%= cliente.telefone %>
                                    </td>
                                    <td>
                                        <%= cliente.email %>
                                    </td>

                                    <td class="acoes">

                                        <button
                                            onclick="window.location.href='/detalhes-cliente/<%= cliente.id_cliente %>'"
                                            class="acoes-icone">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                xmlns="http://www.w3.org/2000/svg">
                                                <path fill-rule="evenodd" clip-rule="evenodd"
                                                    d="M12 17.8C16.034 17.8 19.686 15.55 21.648 12C19.686 8.45 16.034 6.2 12 6.2C7.966 6.2 4.314 8.45 2.352 12C4.314 15.55 7.966 17.8 12 17.8ZM12 5C16.808 5 20.972 7.848 23 12C20.972 16.152 16.808 19 12 19C7.192 19 3.028 16.152 1 12C3.028 7.848 7.192 5 12 5ZM12 14.8C12.7426 14.8 13.4548 14.505 13.9799 13.9799C14.505 13.4548 14.8 12.7426 14.8 12C14.8 11.2574 14.505 10.5452 13.9799 10.0201C13.4548 9.495 12.7426 9.2 12 9.2C11.2574 9.2 10.5452 9.495 10.0201 10.0201C9.495 10.5452 9.2 11.2574 9.2 12C9.2 12.7426 9.495 13.4548 10.0201 13.9799C10.5452 14.505 11.2574 14.8 12 14.8ZM12 16C10.9391 16 9.92172 15.5786 9.17157 14.8284C8.42143 14.0783 8 13.0609 8 12C8 10.9391 8.42143 9.92172 9.17157 9.17157C9.92172 8.42143 10.9391 8 12 8C13.0609 8 14.0783 8.42143 14.8284 9.17157C15.5786 9.92172 16 10.9391 16 12C16 13.0609 15.5786 14.0783 14.8284 14.8284C14.0783 15.5786 13.0609 16 12 16Z"
                                                    fill="#AEAEAE" />
                                            </svg>
                                        </button>
                                        <!--button
                                            onclick="window.location.href='/editar-cliente/<%= cliente.id_cliente %>'"
                                            class="acoes-icone">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                xmlns="http://www.w3.org/2000/svg">
                                                <path
                                                    d="M15.34 7.042L17.608 9.30999M20.65 7.33L17.32 4L4.009 17.311L4 20.65L7.33901 20.641L20.65 7.33Z"
                                                    stroke="#66334D" stroke-width="1.5" stroke-linecap="round"
                                                    stroke-linejoin="round" />
                                            </svg>
                                        </button-->
                                        <button onclick="confirmarExclusao('<%= cliente.id_cliente %>', 'clientes')"
                                            class="acoes-icone">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                xmlns="http://www.w3.org/2000/svg">
                                                <path
                                                    d="M9 3H15M3 5.99303H21M19 5.99303L18.3 16.4886C18.3403 17.5001 18.17 18.5091 17.8 19.4517C17.4987 19.9758 17.0455 20.3966 16.5 20.6589C15.5339 20.9643 14.5147 21.0662 13.507 20.9582H10.489C9.48134 21.0662 8.46211 20.9643 7.49597 20.6589C6.95045 20.3966 6.49726 19.9758 6.19598 19.4517C5.82593 18.5091 5.65568 17.5001 5.69598 16.4886L5 5.99303"
                                                    stroke="#66334D" stroke-width="2" stroke-linecap="round"
                                                    stroke-linejoin="round" />
                                            </svg>
                                        </button>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="4" style="text-align: center;">Nenhum cliente
                                                cadastrado.</td>
                                        </tr>
                                        <% } %>
                    </tbody>

                </table>
            </div>
        </div>
    </div>

    <!--<div id="modal-excluir" class="modal">
        <div class="modal-conteudo">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path
                    d="M2 11.5C2 5.69946 6.69946 1 12.5 1C18.3005 1 23 5.69946 23 11.5C23 17.3005 18.3005 22 12.5 22C6.69946 22 2 17.3005 2 11.5Z"
                    fill="#D52525" fill-opacity="0.2" />
                <path d="M14.6454 9.32054L10.3546 13.6795L14.6454 9.32054Z" fill="#D52525" fill-opacity="0.2" />
                <path d="M10.3546 9.32054L14.6454 13.6795L10.3546 9.32054Z" fill="#D52525" fill-opacity="0.2" />
                <path
                    d="M14.6454 9.32054L10.3546 13.6795M10.3546 9.32054L14.6454 13.6795M2 11.5C2 5.69946 6.69946 1 12.5 1C18.3005 1 23 5.69946 23 11.5C23 17.3005 18.3005 22 12.5 22C6.69946 22 2 17.3005 2 11.5Z"
                    stroke="#D52525" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>

            <p class="titulo-modal">Excluir Cliente</p>
            <p class="texto-modal">Tem certeza que deseja excluir o cliente selecionado?</p>

            <div class="modal-botoes">
                <button class="btn-cancelar" onclick="fecharModal()">Cancelar</button>
                <button class="btn-confirmar" onclick="excluirCliente()">Confirmar</button>
            </div>
        </div>
    </div>-->

    <script>

        function abrirModal() {
            document.getElementById("modal-excluir").style.display = "flex";
        }

        function fecharModal() {
            document.getElementById("modal-excluir").style.display = "none";
        }

    </script>
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="/js/toast.js"></script>
    <script src="/js/formulario.js"></script>
    <script src="/js/pesquisar.js"></script>

</body>
