            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 16px;
            padding: 60px 20px;
            color: #999;
        }

        .favoritos-vazio svg {
            opacity: 0.3;
        }

        .favoritos-vazio p {
            font-size: 16px;
            font-weight: 500;
        }

        .favoritos-vazio a button {
            margin-top: 8px;
            background: #66334D;
            color: #fff;
            border: none;
            padding: 10px 24px;
            border-radius: 8px;
            font-family: 'Montserrat', sans-serif;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
        }

        .favoritos-vazio a button:hover {
            background: #7a3d5c;
        }
    </style>
</head>

