        // Ao desfavoritar nesta página, remove o card da tela
        document.querySelectorAll('.btn-favorito').forEach(svg => {
            svg.addEventListener('click', async () => {
                const idProduto = svg.dataset.id;

                try {
                    const res = await fetch('/favoritos/toggle', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ produto_id: idProduto })
                    });
                    const data = await res.json();

                    // Se desfavoritou, remove o card da tela
                    if (!data.favoritado) {
                        const card = svg.closest('.card-roupa');
                        card.style.transition = 'opacity 0.3s, transform 0.3s';
                        card.style.opacity = '0';
                        card.style.transform = 'scale(0.9)';
                        setTimeout(() => {
                            card.remove();

                            // Se não sobrou nenhum card, mostra mensagem de vazio
                            const cards = document.querySelectorAll('.card-roupa');
                            if (cards.length === 0) location.reload();
                        }, 300);
                    }
                } catch (err) {
                    console.error('Erro ao desfavoritar:', err);
                }
            });
        });
    </script>
