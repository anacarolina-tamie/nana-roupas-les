                                        alt="<%= produto.nome_produto %>">
                                </div>
                                <div class="card-info">
                                    <div class="nome-favorito">
                                        <p>
                                            <%= produto.nome_produto %>
                                        </p>

                                        <!-- Coração sempre preenchido (já é favorito) -->
                                        <svg class="btn-favorito" data-id="<%= produto.id_produto %>" width="24"
                                            height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"
                                            stroke="#66334D" stroke-width="1.5" stroke-linecap="round"
                                            stroke-linejoin="round" style="cursor:pointer; transition: transform .2s;">
                                            <path
                                                d="M19.92 11.9401L18.44 13.4201L12.07 19.7901C12.04 19.8201 12.03 19.8301 12 19.8501C11.97 19.8301 11.96 19.8201 11.93 19.7901L4.08 11.9401C3.19 11.0501 2.75 9.89009 2.75 8.72009C2.75 7.55009 3.19 6.3801 4.08 5.4901C5.86 3.7201 8.74 3.7201 10.52 5.4901L11.99 6.97009L13.47 5.4901C15.25 3.7201 18.12 3.7201 19.9 5.4901C20.81 6.3801 21.25 7.54009 21.25 8.72009C21.25 9.88009 20.81 11.0501 19.92 11.9401Z"
                                                fill="#66334D" />
                                        </svg>
                                    </div>

                                    <div class="preco">
                                        R$ <%= parseFloat(produto.valor_produto).toLocaleString('pt-BR', {
                                            minimumFractionDigits: 2 }) %>
                                    </div>

                                    <% if (parseInt(produto.estoque_total)===0) { %>
                                        <p
                                            style="color: #E8485A; font-size: 12px; font-weight: 600; margin-bottom: 4px;">
                                            Indisponível
                                        </p>
                                        <% } %>

                                            <a href="/produtos/<%= produto.id_produto %>">
                                                <button>Ver detalhes</button>
                                            </a>
                                </div>
                            </div>
                            <% }) %>
                    </div>

                    <% } else { %>
                        <div class="favoritos-vazio">
                            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#66334D"
