<!DOCTYPE html>
<html>
<head>
  <title>Estoque | Nana Roupas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/table.css">
  <link rel="stylesheet" href="/css/navbar.css">
  <link rel="stylesheet" href="/css/general.css">
  <link rel="stylesheet" href="/css/estoque.css">
  <link rel="icon" type="image/png" href="/img/favicon.png">
</head>
<body>

  <div class="containers-tabelaNavbar">
    <div class="navbar-container">
      <%- include('navbar', { paginaAtiva: paginaAtiva }) %>
    </div>

    <div class="layout">
      <div class="titulo-tabela">
        <h1>Estoque</h1>
      </div>

      <div class="containers-tabela">
        <div class="containers-CCF">
          <label class="input-com-icon">
            <input id="input-pesquisar" class="input-pesquisar" type="text"
              placeholder="Pesquisar pelo nome do produto">
            <svg style="cursor:pointer" class="icon-pesquisar" width="20" height="20"
              viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <g clip-path="url(#clip0_526_615)">
                <path d="M19 19L14.65 14.65M8.99999 4C10.3261 4 11.5978 4.5268 12.5355 5.46448C13.4732 6.40216 14 7.67392 14 9M17 9C17 10.5823 16.5308 12.129 15.6517 13.4446C14.7727 14.7602 13.5233 15.7855 12.0614 16.391C10.5996 16.9965 8.9911 17.155 7.43926 16.8463C5.88741 16.5376 4.46195 15.7757 3.34313 14.6569C2.22431 13.538 1.46241 12.1125 1.15373 10.5607C0.845053 9.00882 1.00343 7.40029 1.60893 5.93848C2.21443 4.47667 3.23981 3.22732 4.55541 2.34827C5.871 1.46922 7.41774 1 8.99999 1C11.1217 1 13.1566 1.84285 14.6568 3.34314C16.1571 4.84343 17 6.87827 17 9Z"
                  stroke="#66334D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </g>
              <defs>
                <clipPath id="clip0_526_615"><rect width="20" height="20" fill="white"/></clipPath>
              </defs>
            </svg>
          </label>
          <button id="btn-limpar" class="btn-limpar" style="display:none;">Limpar pesquisa</button>
        </div>

        <div class="layout-tabela">
          <table class="tabela-clientes" id="tabelaEstoque">
            <thead>
              <tr>
                <th>ID</th>
                <th>Produto</th>
                <th>Cor</th>
                <th>Tamanho</th>
                <th>Status</th>
                <th>Qtde em estoque</th>
              </tr>
            </thead>
            <tbody>
              <% if (!variacoes || variacoes.length === 0) { %>
                <tr>
                  <td colspan="6" class="td-vazio">
                    Nenhuma variação de produto encontrada.
                  </td>
                </tr>
              <% } else { %>
                <% variacoes.forEach(v => { %>
                  <%
                    let statusClasse, statusLabel;
                    if (v.estoque === 0) {
                      statusClasse = 'zerado'; statusLabel = 'Sem estoque';
                    } else if (v.estoque <= 5) {
                      statusClasse = 'baixo'; statusLabel = 'Estoque baixo';
                    } else {
                      statusClasse = 'ok'; statusLabel = 'Em estoque';
                    }
                  %>
                  <tr class="linha-variacao"
                      data-nome="<%= (v.nome_produto || '').toLowerCase() %>">
                    <td>#<%= v.id_variacao %></td>
                    <td>
                      <div class="produto-cell">
                        <% if (v.url_imagem) { %>
                          <img class="produto-thumb" src="<%= v.url_imagem %>" alt="<%= v.nome_produto %>">
                        <% } else { %>
                          <div class="produto-thumb produto-thumb-vazio">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                              <rect x="3" y="3" width="18" height="18" rx="3" stroke="#ccc" stroke-width="1.5"/>
                              <path d="M3 9l4-4 4 4 4-4 4 4" stroke="#ccc" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                          </div>
                        <% } %>
                        <%= v.nome_produto %>
                      </div>
                    </td>
                    <td>
                      <span class="cor-chip">
                        <span class="cor-dot" style="background-color: <%= v.hex_cor || '#ccc' %>;"></span>
                        <%= v.nome_cor %>
                      </span>
                    </td>
                    <td><span class="tag-tamanho"><%= v.tamanho %></span></td>
                    <td>
                      <span class="badge-estoque badge-<%= statusClasse %>">
                        <%= statusLabel %>
                      </span>
                    </td>
                    <td><%= v.estoque %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script>
    const inputPesquisar = document.getElementById('input-pesquisar');
    const btnLimpar      = document.getElementById('btn-limpar');

    inputPesquisar.addEventListener('input', function () {
      const termo = this.value.trim().toLowerCase();
      btnLimpar.style.display = termo ? 'inline-block' : 'none';
      document.querySelectorAll('.linha-variacao').forEach(row => {
        row.style.display = row.dataset.nome.includes(termo) ? '' : 'none';
      });
    });

    btnLimpar.addEventListener('click', () => {
      inputPesquisar.value = '';
      btnLimpar.style.display = 'none';
      document.querySelectorAll('.linha-variacao').forEach(r => r.style.display = '');
    });
  </script>
</body>
</html>
