<!DOCTYPE html>
<html>

<head>
  <title>Solicitações de troca | Nana Roupas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/table.css">
  <link rel="stylesheet" href="/css/navbar.css">
  <link rel="stylesheet" href="/css/general.css">
  <link rel="stylesheet" href="/css/mudanca-status.css">
  <link rel="icon" type="image/png" href="/img/favicon.png">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">

  <style>
    .badge-status {
      display: inline-flex;
      align-items: center;
      padding: 3px 10px;
      border-radius: 99px;
      font-size: 12px;
      font-weight: 500;
    }

    .badge-pendente {
      background: #FAEEDA;
      color: #633806;
    }

    .badge-aprovada {
      background: #EAF3DE;
      color: #27500A;
    }

    .badge-negada {
      background: #FCEBEB;
      color: #791F1F;
    }

    .badge-mercadoria-recebida {
      background: #E6F1FB;
      color: #0C447C;
    }

    .badge-recebida {
      background: #E6F1FB;
      color: #0C447C;
    }

    .badge-não-recebida {
      background: #FCEBEB;
      color: #791F1F;
    }

    .badge-devolvida-ao-estoque {
      background: #E1F5EE;
      color: #085041;
    }

    .badge-descartada {
      background: #F0F0F0;
      color: #555;
    }

    .acoes-troca {
      display: flex;
      gap: 8px;
    }

    .btn-acao {
      padding: 6px 13px;
      border-radius: 6px;
      font-size: 12.5px;
      font-weight: 500;
      cursor: pointer;
      border: none;
      font-family: inherit;
    }

    .btn-aprovar {
      background: #66334D;
      color: #fff;
    }

    .btn-negar {
      background: #FCEBEB;
      color: #791F1F;
      border: 1px solid #F7C1C1;
    }

    .btn-receber {
      background: #185FA5;
      color: #fff;
    }

    .tag-motivo {
      display: inline-block;
      background: #f3f0f1;
      border-radius: 4px;
      padding: 2px 7px;
      font-size: 12px;
      color: #7c6b71;
    }

    .btn-estoque {
      background: #185FA5;
      color: #fff;
    }

    .btn-descartar {
      background: #6B6B6B;
      color: #fff;
    }
  </style>
</head>

<body>

  <div class="containers-tabelaNavbar">
    <div class="navbar-container">
      <%- include('navbar', { paginaAtiva: paginaAtiva }) %>
    </div>

    <div class="layout">
      <div class="titulo-tabela">
        <h1>Solicitações de troca</h1>
      </div>

      <div class="containers-tabela">
        <div class="containers-CCF">
          <label class="input-com-icon">
            <input id="input-pesquisar" class="input-pesquisar" type="text"
              placeholder="Pesquisar pelo nº da troca ou nome do cliente">
            <svg id="btn-buscar" style="cursor:pointer" class="icon-pesquisar" width="20" height="20"
              viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <g clip-path="url(#clip0_526_615)">
                <path
                  d="M19 19L14.65 14.65M8.99999 4C10.3261 4 11.5978 4.5268 12.5355 5.46448C13.4732 6.40216 14 7.67392 14 9M17 9C17 10.5823 16.5308 12.129 15.6517 13.4446C14.7727 14.7602 13.5233 15.7855 12.0614 16.391C10.5996 16.9965 8.9911 17.155 7.43926 16.8463C5.88741 16.5376 4.46195 15.7757 3.34313 14.6569C2.22431 13.538 1.46241 12.1125 1.15373 10.5607C0.845053 9.00882 1.00343 7.40029 1.60893 5.93848C2.21443 4.47667 3.23981 3.22732 4.55541 2.34827C5.871 1.46922 7.41774 1 8.99999 1C11.1217 1 13.1566 1.84285 14.6568 3.34314C16.1571 4.84343 17 6.87827 17 9Z"
                  stroke="#66334D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </g>
              <defs>
                <clipPath id="clip0_526_615">
                  <rect width="20" height="20" fill="white" />
                </clipPath>
              </defs>
            </svg>
          </label>
          <button id="btn-limpar" class="btn-limpar" style="display:none;">Limpar pesquisa</button>
        </div>

        <div class="layout-tabela">
          <table class="tabela-clientes" id="tabelaTrocas">
            <thead>
              <tr>
                <th>ID</th>
                <th>Cliente</th>
                <th>Pedido orig.</th>
                <th>Produto</th>
                <th>Motivo</th>
                <th>Qtde</th>
                <th>Status</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              <% if (!solicitacoes || solicitacoes.length===0) { %>
                <tr>
                  <td colspan="8" style="text-align:center; padding:32px; color:#7c6b71;">
                    Nenhuma solicitação de troca encontrada.
                  </td>
                </tr>
                <% } else { %>
                  <% solicitacoes.forEach(s=> { %>
                    <tr class="linha-troca" data-id="<%= s.id_sol_troca %>"
                      data-nome="<%= (s.nome_cliente || '').toLowerCase() %>">
                      <td>#<%= s.id_sol_troca %>
                      </td>
                      <td>
                        <%= s.nome_cliente || '—' %>
                      </td>
                      <td>#<%= s.id_pedido %>
                      </td>
                      <td>
                        <div style="display:flex; align-items:center; gap:8px;">
                          <img src="<%= s.url_imagem %>" alt=""
                            style="width:36px; height:36px; object-fit:cover; border-radius:6px;">
                          <%= s.nome_produto %>
                        </div>
                      </td>
                      <td><span class="tag-motivo">
                          <%= s.motivo_troca || '—' %>
                        </span></td>
                      <td>
                        <%= s.qtde_item %>
                      </td>
                      <td>
                        <span class="badge-status badge-<%= s.status_troca.toLowerCase().replace(/ /g, '-') %>">
                          <%= s.status_troca %>
                        </span>
                      </td>
                      <td>
                        <div class="acoes-troca">
                          <% if (s.status_troca==='Pendente' ) { %>
                            <button class="btn-acao btn-aprovar"
                              onclick="abrirModal(<%= s.id_sol_troca %>, 'aprovar', '<%= s.nome_cliente %>')">Aprovar</button>
                            <button class="btn-acao btn-negar"
                              onclick="abrirModal(<%= s.id_sol_troca %>, 'negar', '<%= s.nome_cliente %>')">Negar</button>

                            <% } else if (s.status_troca==='Aprovada' ) { %>
                              <button class="btn-acao btn-receber"
                                onclick="abrirModal(<%= s.id_sol_troca %>, 'recebida', '<%= s.nome_cliente %>')">Recebido</button>
                              <button class="btn-acao btn-negar"
                                onclick="abrirModal(<%= s.id_sol_troca %>, 'nao-recebida', '<%= s.nome_cliente %>')">Não
                                recebido</button>

                              <% } else if (s.status_troca==='Recebida' ) { %>
                                <button class="btn-acao btn-estoque"
                                  onclick="abrirModal(<%= s.id_sol_troca %>, 'devolver-estoque', '<%= s.nome_cliente %>')">Estoque</button>
                                <button class="btn-acao btn-descartar"
                                  onclick="abrirModal(<%= s.id_sol_troca %>, 'descartar', '<%= s.nome_cliente %>')">Descartar</button>

                                <% } else { %>
                                  <span style="color:#aaa; font-size:12px;">—</span>
                                  <% } %>
                        </div>
                      </td>
                    </tr>
                    <% }) %>
                      <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- MODAL DE CONFIRMAÇÃO -->
  <div class="modal-backdrop-pedido" id="modalBackdrop">
    <div class="modal-pedido">
      <h3 id="modalTitulo">Confirmar ação</h3>
      <p id="modalDescricao">Tem certeza?</p>
      <div class="modal-pedido-footer">
        <button class="btn-modal-cancel" id="btnModalCancelar">Cancelar</button>
        <button class="btn-modal-confirm" id="btnModalConfirmar">Confirmar</button>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  <script>
    // ── Pesquisa ──────────────────────────────────────────────────────
    document.getElementById('input-pesquisar').addEventListener('input', function () {
      const termo = this.value.trim().toLowerCase();
      document.getElementById('btn-limpar').style.display = termo ? 'inline-block' : 'none';
      document.querySelectorAll('.linha-troca').forEach(row => {
        const id = row.dataset.id.toLowerCase();
        const nome = row.dataset.nome.toLowerCase();
        row.style.display = (id.includes(termo) || nome.includes(termo)) ? '' : 'none';
      });
    });
    document.getElementById('btn-limpar').addEventListener('click', function () {
      document.getElementById('input-pesquisar').value = '';
      this.style.display = 'none';
      document.querySelectorAll('.linha-troca').forEach(r => r.style.display = '');
    });

    // ── Modal ─────────────────────────────────────────────────────────
    const TEXTOS = {
      aprovar: { titulo: 'Aprovar troca', desc: (id, nome) => `Aprovar a troca #${id} de ${nome}? O cliente será notificado.`, classe: 'aprovar' },
      negar: { titulo: 'Negar troca', desc: (id, nome) => `Negar a troca #${id} de ${nome}? O cliente será notificado e o fluxo encerrado.`, classe: 'reprovar' },
      'recebida': { titulo: 'Confirmar recebimento', desc: (id, nome) => `Confirmar que a mercadoria da troca #${id} de ${nome} foi recebida?`, classe: 'aprovar' },
      'nao-recebida': { titulo: 'Mercadoria não recebida', desc: (id, nome) => `Marcar a troca #${id} de ${nome} como mercadoria não recebida?`, classe: 'reprovar' },
      'devolver-estoque': { titulo: 'Devolver ao estoque', desc: (id, nome) => `Devolver os produtos da troca #${id} de ${nome} ao estoque?`, classe: 'aprovar' },
      'descartar': { titulo: 'Descartar mercadoria', desc: (id, nome) => `Descartar os produtos da troca #${id} de ${nome}? Esta ação não pode ser desfeita.`, classe: 'reprovar' },
    };

    const ENDPOINTS = {
      aprovar: id => `/solicitacoes-troca/${id}/aprovar`,
      negar: id => `/solicitacoes-troca/${id}/negar`,
      'recebida': id => `/solicitacoes-troca/${id}/recebida`,
      'nao-recebida': id => `/solicitacoes-troca/${id}/nao-recebida`,
      'devolver-estoque': id => `/solicitacoes-troca/${id}/devolver-estoque`,
      'descartar': id => `/solicitacoes-troca/${id}/descartar`,
    };
    let acaoPendente = null;

    function abrirModal(idTroca, acao, nomeCliente) {
      const cfg = TEXTOS[acao];
      document.getElementById('modalTitulo').textContent = cfg.titulo;
      document.getElementById('modalDescricao').textContent = cfg.desc(idTroca, nomeCliente);
      const btnConfirmar = document.getElementById('btnModalConfirmar');
      btnConfirmar.className = 'btn-modal-confirm ' + cfg.classe;
      acaoPendente = { idTroca, acao };
      document.getElementById('modalBackdrop').classList.add('aberto');
    }

    document.getElementById('btnModalCancelar').addEventListener('click', () => {
      document.getElementById('modalBackdrop').classList.remove('aberto');
      acaoPendente = null;
    });
    document.getElementById('modalBackdrop').addEventListener('click', e => {
      if (e.target === e.currentTarget) {
        document.getElementById('modalBackdrop').classList.remove('aberto');
        acaoPendente = null;
      }
    });

    document.getElementById('btnModalConfirmar').addEventListener('click', async () => {
      if (!acaoPendente) return;
      const { idTroca, acao } = acaoPendente;
      const btn = document.getElementById('btnModalConfirmar');
      btn.disabled = true;
      btn.textContent = 'Aguarde...';

      try {
        const res = await fetch(ENDPOINTS[acao](idTroca), { method: 'POST', credentials: 'include' });
        const data = await res.json();
        document.getElementById('modalBackdrop').classList.remove('aberto');
        acaoPendente = null;

        Toastify({
          text: data.mensagem,
          duration: 3500,
          gravity: 'top',
          position: 'right',
          style: { background: res.ok ? '#66334D' : '#c0392b' }
        }).showToast();

        if (res.ok) setTimeout(() => location.reload(), 1500);
      } catch (err) {
        Toastify({ text: 'Falha na conexão. Tente novamente.', duration: 3000, style: { background: '#c0392b' } }).showToast();
      } finally {
        btn.disabled = false;
        btn.textContent = 'Confirmar';
      }
    });
  </script>
</body>

</html>